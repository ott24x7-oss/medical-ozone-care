# ===== Medical Ozone Care — environment variables =====
# Copy to ".env" and fill in. Locally run:  npm run start:prod
# On Railway/Render, set these in the platform's Variables UI (no .env file needed).

# Server
PORT=3000

# Admin login (seeded on first run only — change the password!)
ADMIN_EMAIL=medicalozonecare@gmail.com
ADMIN_PASSWORD=change-this-strong-password

# Secret used to sign admin session tokens (use a long random string)
SESSION_SECRET=replace-with-a-long-random-secret

# Email notifications (optional). If unset, enquiries are still saved and the
# notification is logged to the server console instead of emailed.
# Example for Gmail: create an "App Password" and use it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=medicalozonecare@gmail.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM=Medical Ozone Care <medicalozonecare@gmail.com>
# Where new-enquiry notifications are sent (comma-separated):
NOTIFY_TO=shekharaiims@gmail.com,medicalozonecare@gmail.com
