.env

# database (created at runtime, reseeds on first run)
server/data/*.db
server/data/*.db-journal
server/data/*.db-wal
server/data/*.db-shm

# admin-uploaded assets (runtime)
public/assets/img/products/uploads/
public/assets/docs/

*.log
.DS_Store
Thumbs.db

# scratch
pdf_text.txt
pdf_images/
pdf_view/
preview_png/

# PHP version (Hostinger) runtime artifacts
# (config.php ships with placeholder values — the user edits it on the server)
php/data/*.sqlite
php/data/*.sqlite3
php/uploads/*
!php/uploads/.gitkeep
!php/uploads/.htaccess

# portable PHP used only for local linting/testing
.phpbin/
php_portable.zip

# build artifacts
*.zip
